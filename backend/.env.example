# App Settings
APP_NAME="SIH 25162 - AOI IC Verification"
APP_VERSION="1.0.0"
DEBUG=True

# CORS (comma-separated origins)
CORS_ORIGINS="http://localhost:5173,http://localhost:3000"

# YOLO Model
YOLO_MODEL_PATH="https://github.com/ultralytics/assets/releases/download/v0.0.0/yolov8n.pt"
YOLO_CONFIDENCE=0.25
YOLO_DEVICE="cpu"

# Security (JWT)
# Generate SECRET_KEY with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY="CHANGE_ME"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
ADMIN_USERNAME="admin"
# Generate hash with: python -c "import bcrypt; print(bcrypt.hashpw(b'your_password', bcrypt.gensalt()).decode())"
ADMIN_PASSWORD_HASH=""

# Upload limits
MAX_UPLOAD_SIZE_MB=10
MAX_BATCH_FILES=20

# Mouser API
MOUSER_API_KEY=""

# AI Agent (Groq - get key from https://console.groq.com)
GROQ_API_KEY=""
AI_MODEL="llama-3.3-70b-versatile"
AI_ENABLED=True
