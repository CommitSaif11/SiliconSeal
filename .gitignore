# =========================================
#  PYTHON (Backend)
# =========================================

backend/__pycache__/
backend/**/*.pyc
backend/**/*.pyo
backend/**/*.pyd

# Virtual environments
backend/.venv/
backend/env/
backend/venv/

# Environment files (keep .env.example for documentation)
backend/.env
backend/.env.*
!backend/.env.example

# Build artifacts
backend/build/
backend/dist/
backend/wheels/
backend/*.egg-info

# Logs
backend/*.log

# YOLO model weights
backend/**/*.pt
backend/**/*.onnx
backend/**/*.engine
backend/**/*.mlmodel

# Temporary / cache
backend/*.tmp
backend/*.swp
backend/*.bak
backend/.reload/

# Test images and dev scripts
backend/*.png
backend/*.jpg
backend/*.jpeg
backend/test_*.py
backend/improved_*.py
backend/inspect_*.py


# =========================================
#  NODE / FRONTEND (Future)
# =========================================

frontend/node_modules/
frontend/dist/
frontend/.env
frontend/.env.*


# =========================================
#  GLOBAL IGNORE (Applies everywhere)
# =========================================

.DS_Store
Thumbs.db
.vscode/
documentation/
